@page "/my-loans"
@using LibraryManagement.Features.Data
@using LibraryManagement.Features.Data.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject AppDbContext Db
@inject CurrentUserService CurrentUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>My Loans</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-8">
    <MudText Typo="Typo.h3" Class="mb-8">My Loans</MudText>
    
    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6" Elevation="3">
                <MudGrid>
                    <MudItem xs="4">
                        <MudIcon Icon="@Icons.Material.Filled.LibraryAdd" Size="Size.Large" Color="Color.Success" />
                    </MudItem>
                    <MudItem xs="8" Class="text-end">
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Active Loans</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Success">@activeLoans</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6" Elevation="3">
                <MudGrid>
                    <MudItem xs="4">
                        <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                    </MudItem>
                    <MudItem xs="8" Class="text-end">
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Overdue Loans</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Error">@overdueLoans</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6" Elevation="3">
                <MudGrid>
                    <MudItem xs="4">
                        <MudIcon Icon="@Icons.Material.Filled.LibraryAddCheck" Size="Size.Large" Color="Color.Secondary" />
                    </MudItem>
                    <MudItem xs="8" Class="text-end">
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Returned Books</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Secondary">@returnedBooks</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (myLoans.Any())
    {
        <MudPaper Class="pa-8" Elevation="3">
            <MudText Typo="Typo.h5" Class="mb-6">Active Loans</MudText>
            <MudTable Items="myLoans" Hover="true" Bordered="true" Striped="true">
                <HeaderContent>
                    <MudTh>Book Title</MudTh>
                    <MudTh>Author</MudTh>
                    <MudTh>Loan Date</MudTh>
                    <MudTh>Due Date</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Book Title">@context.Book?.Title</MudTd>
                    <MudTd DataLabel="Author">@context.Book?.Author?.Name</MudTd>
                    <MudTd DataLabel="Loan Date">@context.LoanDate.ToShortDateString()</MudTd>
                    <MudTd DataLabel="Due Date">
                        <MudText Color="@(context.DueDate < DateTime.UtcNow ? Color.Error : Color.Default)">
                            @context.DueDate.ToShortDateString()
                            @if (context.DueDate < DateTime.UtcNow)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-2" Icon="@Icons.Material.Filled.Error">Overdue</MudChip>
                            }
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.LibraryAddCheck" OnClick="() => ReturnBook(context.Id)">
                            Return
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-12 text-center" Elevation="3">
            <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Large" Color="Color.Primary" Class="mb-6" />
            <MudText Typo="Typo.h5" Class="mb-3">No active loans</MudText>
            <MudText Typo="Typo.body1" Color="Color.Inherit" Class="mb-8">
                Explore our collection and borrow your first book today!
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Book" Href="/books">
                Browse Books Now
            </MudButton>
        </MudPaper>
    }
</MudContainer>

@code {
    private int activeLoans = 0;
    private int overdueLoans = 0;
    private int returnedBooks = 0;
    private List<Loan> myLoans = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        if (CurrentUserService.Id.HasValue)
        {
            myLoans = await Db.Loans
                .Include(l => l.Book)
                .ThenInclude(b => b.Author)
                .Where(l => l.MemberId == CurrentUserService.Id && !l.ReturnDate.HasValue)
                .ToListAsync();

            activeLoans = myLoans.Count;
            overdueLoans = myLoans.Count(l => l.DueDate < DateTime.UtcNow);
            returnedBooks = await Db.Loans
                .CountAsync(l => l.MemberId == CurrentUserService.Id && l.ReturnDate.HasValue);
        }
    }

    private async Task ReturnBook(int loanId)
    {
        var loan = await Db.Loans.FindAsync(loanId);
        if (loan == null) return;

        loan.ReturnDate = DateTime.UtcNow;
        var book = await Db.Books.FindAsync(loan.BookId);
        if (book != null)
        {
            book.AvailableCopies++;
        }

        await Db.SaveChangesAsync();
        await LoadData();
        Snackbar.Add("Book returned successfully!", Severity.Success);
    }
}
